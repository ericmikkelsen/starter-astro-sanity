{
	"name": "starter-astro-sanity",
	"version": "1.0.0",
	"description": "Astro v6 + Sanity v3 starter with Tailwind v4, TypeScript strict mode, and draft preview",
	"private": true,
	"scripts": {
		"dev": "concurrently \"astro dev\" \"sanity dev --port 3333\"",
		"build": "astro build",
		"studio": "sanity dev --port 3333",
		"typegen": "sanity typegen generate",
		"format": "prettier --write .",
		"prepare": "husky"
	},
	"dependencies": {
		"@sanity/client": "^7.22.0",
		"@tailwindcss/vite": "^4.2.4",
		"astro": "^5.18.1",
		"concurrently": "^9.2.1",
		"sanity": "^5.22.0",
		"tailwindcss": "^4.2.4"
	},
	"lint-staged": {
		"*.{js,jsx,ts,tsx,mjs,cjs,vue,svelte,astro,css,scss,sass,less,html,svg,json,yaml,yml,md}": "prettier --write"
	},
	"devDependencies": {
		"@commitlint/cli": "^20.5.2",
		"@commitlint/config-conventional": "^20.5.0",
		"@semantic-release/changelog": "^6.0.3",
		"@semantic-release/commit-analyzer": "^13.0.1",
		"@semantic-release/git": "^10.0.1",
		"@semantic-release/github": "^12.0.6",
		"@semantic-release/npm": "^13.1.5",
		"@semantic-release/release-notes-generator": "^14.1.0",
		"conventional-changelog-conventionalcommits": "^9.1.0",
		"husky": "^9.0.0",
		"lint-staged": "^16.4.0",
		"prettier": "^3.8.3",
		"prettier-plugin-astro": "^0.14.1",
		"semantic-release": "^25.0.3"
	}
}
