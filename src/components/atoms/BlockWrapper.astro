---
/**
 * Shared wrapper for block components so renderer-level semantics (`header` vs
 * `section`) stay centralized and consistent.
 */
interface Props {
const { as, class: className = '' }: Props = Astro.props;
	class?: string;
}

const { as, class: className = '' } = Astro.props;
---

{
	as === 'header' ? (
		<header class={className}>
			<slot />
		</header>
	) : (
		<section class={className}>
			<slot />
		</section>
	)
}
