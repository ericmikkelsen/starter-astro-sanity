---
import type ImageType from '../../types/image';
import { Image as AstroImage } from 'astro:assets';
interface Props extends ImageType {
	class?: string;
}

const {
	src = '',
	alt = '',
	width,
	height,
	priority,
	class: className,
} = Astro.props as Props;
---

<AstroImage
	alt={alt}
	class={className}
	height={height}
	src={src}
	width={width}
/>
