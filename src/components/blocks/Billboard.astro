---
import type Link from '../../types/link';
import type ImageType from '../../types/image';
import type {
	ArrayPageBuilderBlockByType,
	BlockSettings
} from '../../lib/content/pageBuilderTypes';
import BlockWrapper from '../atoms/BlockWrapper.astro';
import Heading from '../atoms/Heading.astro';
import Image from '../atoms/Image.astro';

/**
 * Billboard block content plus shared renderer settings.
 */
interface Props
	extends
		Omit<ArrayPageBuilderBlockByType<'billboard'>, '_type'>,
		BlockSettings {
	link?: Link;
	image?: ImageType;
}

const {
	heading = '',
	body = '',
	as,
	hLevel,
	priority,
	link = { text: '', url: '' },
	image
} = Astro.props as Props;
---

<BlockWrapper as={as}>
	<Heading hLevel={hLevel}>
		{heading}
	</Heading>
	{body.length ? <p>{body}</p> : null}
	{
		link?.text.length && link?.url.length ? (
			<a href={link.url}>{link.text}</a>
		) : null
	}
	{
		image?.src ? (
			<Image {...(image as Required<ImageType>)} priority={priority} />
		) : null
	}
</BlockWrapper>
