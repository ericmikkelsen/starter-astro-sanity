---
import type { ArrayPageBuilderBlock } from '../../lib/content/pageBuilderTypes';
import Billboard from './Billboard.astro';
import ListScroller from './listScroller.astro';
import PeopleRefs from './peopleRefs.astro';
import RichText from './richText.astro';

interface Props {
	data: ArrayPageBuilderBlock;
	index?: number;
}

const { data, index = 0 } = Astro.props as Props;
---

{
	data._type === 'billboard' ? (
		<Billboard
			heading={data.heading ?? ''}
			body={data.body}
			index={index}
		/>
	) : data._type === 'listScroller' ? (
		<ListScroller {...data} />
	) : data._type === 'peopleRefs' ? (
		<PeopleRefs {...data} />
	) : data._type === 'richText' ? (
		<RichText {...data} />
	) : null
}
