---
import type {
	ArrayPageBuilderBlockByType,
	BlockSettings
} from '../../lib/content/pageBuilderTypes';
import Heading from '../atoms/Heading.astro';
import BlockWrapper from '../atoms/BlockWrapper.astro';

/**
 * List scroller content plus shared renderer settings from the block renderer.
 */
interface Props
	extends
		Omit<ArrayPageBuilderBlockByType<'listScroller'>, '_type'>,
		BlockSettings {}

const {
	heading = '',
	body = '',
	items = [],
	hLevel,
	as
} = Astro.props as Props;
// Keep visual chrome consistent across blocks while allowing semantic wrapper changes.
const wrapperClass = 'rounded-lg border border-stone-200 bg-white p-5';
---

<BlockWrapper as={as} class={wrapperClass}>
	{
		heading ? (
			<Heading hLevel={hLevel} class="text-2xl font-semibold">
				{heading}
			</Heading>
		) : null
	}
	{body ? <p class="mt-2 text-stone-700">{body}</p> : null}
	{
		items.length ? (
			<ul class="mt-3 list-disc space-y-1 pl-5 text-stone-700">
				{items.map((item) => (
					<li>{item}</li>
				))}
			</ul>
		) : null
	}
</BlockWrapper>
