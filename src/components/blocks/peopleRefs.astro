---
import type {
	ArrayPageBuilderBlockByType,
	BlockSettings,
} from '../../lib/content/pageBuilderTypes';
import Heading from '../atoms/Heading.astro';

interface Props
	extends
		Omit<ArrayPageBuilderBlockByType<'peopleRefs'>, '_type'>,
		BlockSettings {}

const {
	heading = '',
	body = '',
	people = [],
	hLevel,
	as,
} = Astro.props as Props;
const Wrapper = as === 'header' ? 'header' : 'section';
---

{
	as === 'header' ? (
		<header class="rounded-lg border border-stone-200 bg-white p-5">
			{heading ? (
				<Heading hLevel={hLevel} class="text-2xl font-semibold">
					{heading}
				</Heading>
			) : null}
			{body ? <p class="mt-2 text-stone-700">{body}</p> : null}
			{people.length ? (
				<ul class="mt-3 list-disc space-y-1 pl-5 text-stone-700">
					{people.map((person) => (
						<li>{person.name ?? person._id}</li>
					))}
				</ul>
			) : null}
		</header>
	) : (
		<section class="rounded-lg border border-stone-200 bg-white p-5">
			{heading ? (
				<Heading hLevel={hLevel} class="text-2xl font-semibold">
					{heading}
				</Heading>
			) : null}
			{body ? <p class="mt-2 text-stone-700">{body}</p> : null}
			{people.length ? (
				<ul class="mt-3 list-disc space-y-1 pl-5 text-stone-700">
					{people.map((person) => (
						<li>{person.name ?? person._id}</li>
					))}
				</ul>
			) : null}
		</section>
	)
}
