---
import type { ArrayPageBuilderBlockByType } from '../../lib/content/pageBuilderTypes';

interface Props extends Omit<
	ArrayPageBuilderBlockByType<'richText'>,
	'_type'
> {}

const { heading = '', body = '', richText = [] } = Astro.props as Props;
---

<section class="rounded-lg border border-stone-200 bg-white p-5">
	{heading ? <h2 class="text-2xl font-semibold">{heading}</h2> : null}
	{body ? <p class="mt-2 text-stone-700">{body}</p> : null}
	{
		richText.length ? (
			<p class="mt-2 text-stone-700">
				{richText.length} rich text block(s)
			</p>
		) : null
	}
</section>
