---
import type {
	ArrayPageBuilderBlockByType,
	BlockSettings,
} from '../../lib/content/pageBuilderTypes';
import Heading from '../atoms/Heading.astro';

interface Props
	extends
		Omit<ArrayPageBuilderBlockByType<'richText'>, '_type'>,
		BlockSettings {}

const {
	heading = '',
	body = '',
	richText = [],
	hLevel,
	as,
} = Astro.props as Props;
---

{
	as === 'header' ? (
		<header class="rounded-lg border border-stone-200 bg-white p-5">
			{heading ? (
				<Heading hLevel={hLevel} class="text-2xl font-semibold">
					{heading}
				</Heading>
			) : null}
			{body ? <p class="mt-2 text-stone-700">{body}</p> : null}
			{richText.length ? (
				<p class="mt-2 text-stone-700">
					{richText.length} rich text block(s)
				</p>
			) : null}
		</header>
	) : (
		<section class="rounded-lg border border-stone-200 bg-white p-5">
			{heading ? (
				<Heading hLevel={hLevel} class="text-2xl font-semibold">
					{heading}
				</Heading>
			) : null}
			{body ? <p class="mt-2 text-stone-700">{body}</p> : null}
			{richText.length ? (
				<p class="mt-2 text-stone-700">
					{richText.length} rich text block(s)
				</p>
			) : null}
		</section>
	)
}
