---
import Blocks from '../blocks/_blocks.astro';
import type { AstroPage } from '../../lib/content/pages';

interface Props {
	page: AstroPage;
}

const { page } = Astro.props as Props;
const hasBlocks = Boolean(page.blocks?.length);
---

<div class="mx-auto flex min-h-screen max-w-3xl flex-col gap-4 px-6 py-14">
	<a
		class="text-sm font-semibold tracking-[0.14em] text-emerald-700 uppercase"
		href="/">Back to home</a
	>
	<h1 class="text-4xl leading-tight font-bold">{page.title}</h1>
	{
		page.description ? (
			<p class="text-lg text-stone-700">{page.description}</p>
		) : null
	}
	<div class="mt-4 grid gap-5">
		<Blocks blockData={page.blocks} />
		{
			hasBlocks ? null : (
				<p class="text-sm text-stone-600">
					No blocks configured for this page yet.
				</p>
			)
		}
	</div>
</div>
