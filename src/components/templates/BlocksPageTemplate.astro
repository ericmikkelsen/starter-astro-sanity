---
import Blocks from '../blocks/_blocks.astro';
import type { AstroPage } from '../../lib/content/pages';

interface Props {
	page: AstroPage;
}

const { page } = Astro.props as Props;
const hasBlocks = Boolean(page.blocks?.length);
---

<Blocks blockData={page.blocks} />
{
	hasBlocks ? null : (
		<p class="text-sm text-stone-600">
			No blocks configured for this page yet.
		</p>
	)
}
