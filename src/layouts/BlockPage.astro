---
import '../styles/global.css';
import HTML from './html.astro';
import BlocksPageTemplate from '../components/templates/BlocksPageTemplate.astro';

interface Props {
	title: string;
	description?: string;
	page: any;
}

const { title, description, page } = Astro.props as Props;
---

<HTML title={title} description={description}>
	<BlocksPageTemplate page={page} />
</HTML>
