---
import { getClient } from '../sanity/client';
import { allPagesQuery, pageBySlugQuery } from '../sanity/queries';
import type { PageBySlugQueryResult } from '../sanity/types';
import '../styles/global.css';

export async function getStaticPaths() {
	try {
		const pages = await getClient().fetch(allPagesQuery);
		return pages
			.filter((page) => page.slug?.current)
			.map((page) => ({ params: { slug: page.slug!.current } }));
	} catch {
		// Sanity not yet configured — build succeeds with no pages
		return [];
	}
}

const { slug } = Astro.params;

const isPreview =
	Astro.url.searchParams.has('preview') &&
	Astro.url.searchParams.get('preview') === import.meta.env.SANITY_API_TOKEN;

const page: PageBySlugQueryResult = await getClient(isPreview).fetch(
	pageBySlugQuery,
	{ slug }
);

if (!page) {
	return Astro.redirect('/404');
}
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>{page.title}</title>
		{
			page.description && (
				<meta name="description" content={page.description} />
			)
		}
	</head>
	<body class="max-w-2xl mx-auto px-4 py-12">
		<nav class="mb-8">
			<a href="/" class="text-blue-600 hover:underline text-sm"
				>← All pages</a
			>
		</nav>
		<h1 class="text-3xl font-bold mb-4">{page.title}</h1>
		{page.description && <p class="text-gray-600">{page.description}</p>}
	</body>
</html>
