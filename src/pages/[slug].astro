---
import '../styles/global.css';

import BlocksPageTemplate from '../components/templates/BlocksPageTemplate.astro';
import { getAstroPages } from '../lib/content/pages';
import HTML from '../layouts/html.astro';
export async function getStaticPaths() {
	const pages = await getAstroPages();

	return pages.map((page) => ({
		params: { slug: page.slug },
		props: {
			page,
			title: page.title,
			description: page.description,
		},
	}));
}

const { title = '', description = '', page } = Astro.props;
---

<HTML title={title} description={description}>
	<BlocksPageTemplate page={page} />
</HTML>
