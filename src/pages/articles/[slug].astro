---
import '../../styles/global.css';
import { getCollection } from 'astro:content';
import PortablePage from '../../layouts/PortablePage.astro';
import type { ArticleCollectionEntryData } from '../../lib/content/articleCollection';

interface Props {
	entry: ArticleCollectionEntryData;
	title?: string;
	description?: string;
}

export async function getStaticPaths() {
	const entries = await getCollection('article');
	return entries.map((entry) => ({
		params: { slug: entry.data.slug },
		props: {
			entry: entry.data,
			title: entry.data.title,
			description: entry.data.description
		}
	}));
}

const { entry, title = '', description = '' } = Astro.props as Props;
---

<PortablePage
	title={entry.title}
	description={entry.description}
	body={entry.body}
	urlPrefix="articles"
/>
