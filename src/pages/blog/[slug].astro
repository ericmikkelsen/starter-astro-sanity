---
import '../../styles/global.css';
import HTML from '../../layouts/html.astro';
import BlogPostTemplate from '../../components/templates/BlogPostTemplate.astro';
import { getAstroBlogPosts } from '../../lib/content/blog';

export async function getStaticPaths() {
	const posts = await getAstroBlogPosts();
	return posts.map((post) => ({
		params: { slug: post.slug },
		props: { post, title: post.title, description: post.description },
	}));
}

const { post, title = '', description = '' } = Astro.props;
---

<HTML title={title} description={description}>
	<BlogPostTemplate post={post} />
</HTML>
