---
import '../styles/global.css';

import { getAstroPages } from '../lib/content/pages';
import { isPreviewEnabled } from '../lib/content/preview';

const pages = await getAstroPages();
const previewEnabled = isPreviewEnabled();
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<title>Astro + Sanity Starter</title>
	</head>
	<body class="bg-stone-50 text-stone-900">
		<main
			class="mx-auto flex min-h-screen max-w-3xl flex-col gap-8 px-6 py-14"
		>
			<header class="space-y-3">
				<p
					class="text-sm font-semibold tracking-[0.18em] text-emerald-700 uppercase"
				>
					Pages
				</p>
				<h1 class="text-4xl leading-tight font-bold">
					Astro pages from Sanity content
				</h1>
				<p class="text-lg text-stone-700">
					Sanity Studio is mounted at
					<a
						class="font-semibold text-emerald-700 underline underline-offset-4"
						href="/studio">/studio</a
					>.
				</p>
			</header>

			<section
				class="rounded-xl border border-stone-200 bg-white p-5 shadow-sm"
			>
				<h2
					class="text-base font-semibold tracking-wide text-stone-600 uppercase"
				>
					Routing status
				</h2>
				<p class="mt-2 text-stone-700">
					{
						previewEnabled
							? 'Preview scaffolding enabled (draft perspective).'
							: 'Preview scaffolding disabled (published perspective).'
					}
				</p>
			</section>

			<section
				class="rounded-xl border border-stone-200 bg-white p-5 shadow-sm"
			>
				<h2
					class="text-base font-semibold tracking-wide text-stone-600 uppercase"
				>
					Page links
				</h2>
				{
					pages.length === 0 ? (
						<p class="mt-3 text-stone-700">
							No pages found yet. Create one in Sanity Studio to
							generate a route.
						</p>
					) : (
						<ul class="mt-3 grid gap-3">
							{pages.map((page) => (
								<li class="rounded-lg border border-stone-200 p-4">
									<a
										class="text-lg font-semibold text-emerald-700 underline underline-offset-4"
										href={page.path}
									>
										{page.title}
									</a>
									{page.description ? (
										<p class="mt-1 text-stone-700">
											{page.description}
										</p>
									) : null}
								</li>
							))}
						</ul>
					)
				}
			</section>
		</main>
	</body>
</html>
