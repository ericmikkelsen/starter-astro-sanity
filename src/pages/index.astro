---
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<title>Astro + Sanity Starter</title>
	</head>
	<body class="bg-stone-50 text-stone-900">
		<main class="mx-auto flex min-h-screen max-w-3xl flex-col justify-center gap-8 px-6 py-14">
			<header class="space-y-3">
				<p class="text-sm font-semibold uppercase tracking-[0.18em] text-emerald-700">Chapter 01</p>
				<h1 class="text-4xl font-bold leading-tight">Astro + Sanity starter is bootstrapped.</h1>
				<p class="text-lg text-stone-700">
					Sanity Studio is mounted at
					<a class="font-semibold text-emerald-700 underline underline-offset-4" href="/studio">/studio</a>.
				</p>
			</header>
			<section class="rounded-xl border border-stone-200 bg-white p-5 shadow-sm">
				<h2 class="text-base font-semibold uppercase tracking-wide text-stone-600">Next chapters</h2>
				<ul class="mt-3 list-disc space-y-2 pl-6 text-stone-700">
					<li>Add page schema and shared field types.</li>
					<li>Generate static page routes from Sanity documents.</li>
					<li>Wire SSR preview behavior and baseline tests.</li>
				</ul>
			</section>
		</main>
	</body>
</html>