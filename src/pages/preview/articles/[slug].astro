---
import { loadQuery } from '../../../lib/content/preview';
import {
	SANITY_ARTICLE_COLLECTION_QUERY,
	mapSanityArticleToCollectionEntry,
	type SanityArticleQueryResult
} from '../../../lib/content/articleCollection';
import HTML from '../../../layouts/html.astro';
import PortablePage from '../../../layouts/PortablePage.astro';

export const prerender = false;

const slug = Astro.params.slug;
let entry: ReturnType<typeof mapSanityArticleToCollectionEntry> = null;

if (slug) {
	const results = await loadQuery<SanityArticleQueryResult[]>(
		SANITY_ARTICLE_COLLECTION_QUERY
	);
	const match = results.find((result) => result.slug === slug);
	entry = match ? mapSanityArticleToCollectionEntry(match) : null;
}

if (!entry) {
	Astro.response.status = 404;
}

const title = entry?.data.title ?? 'Preview not found';
const description =
	entry?.data.description ?? 'The requested preview page was not found.';
---

{
	entry ? (
		<PortablePage
			title={entry.data.title}
			description={entry.data.description}
			body={entry.data.body}
			urlPrefix="articles"
		/>
	) : (
		<HTML title={title} description={description}>
			<div class="mx-auto max-w-3xl px-6 py-14 text-stone-700">
				Preview page not found.
			</div>
		</HTML>
	)
}
